              "x": 230,
              "y": 22,
              "width": 70,
              "height": 40,
              "content": "60%",
              "fontSize": 34,
              "fontWeight": 800,
              "fill": "#FFFFFF"
            },
            {
              "id": "progress-track",
              "type": "rectangle",
              "x": 28,
              "y": 95,
              "width": 270,
              "height": 10,
              "cornerRadius": 999,
              "fill": "rgba(255,255,255,0.25)"
            },
            {
              "id": "progress-value",
              "type": "rectangle",
              "x": 28,
              "y": 95,
              "width": 162,
              "height": 10,
              "cornerRadius": 999,
              "fill": "#FFFFFF"
            },
            {
              "id": "progress-subtext",
              "type": "text",
              "x": 28,
              "y": 128,
              "width": 180,
              "height": 24,
              "content": "10개 중 6개 완료",
