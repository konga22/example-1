          "y": 210,
          "width": 326,
          "height": 190,
          "cornerRadius": 28,
          "fill": {
            "type": "gradient",
            "kind": "linear",
            "from": { "x": 0, "y": 0 },
            "to": { "x": 1, "y": 1 },
            "stops": [
              { "offset": 0, "color": "#7E57FF" },
              { "offset": 1, "color": "#9168FF" }
            ]
          },
          "children": [
            {
              "id": "progress-label",
