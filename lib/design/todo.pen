{
  "children": [
    {
      "id": "todo-screen",
      "type": "frame",
      "x": 120,
      "y": 80,
      "width": 390,
      "height": 844,
      "fill": "#F7F7FB",
      "cornerRadius": 32,
      "children": [
        {
          "id": "hello-text",
          "type": "text",
          "x": 32,
          "y": 70,
          "width": 120,
          "height": 24,
          "content": "안녕하세요",
          "fontSize": 18,
          "fontWeight": 500,
          "fill": "#8A8A8A"
        },
        {
          "id": "title-text",
          "type": "text",
          "x": 32,
          "y": 110,
          "width": 220,
          "height": 56,
          "content": "나의 할 일",
          "fontSize": 42,
          "fontWeight": 800,
          "fill": "#111111"
        },
        {
